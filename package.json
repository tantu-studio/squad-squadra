{
  "name": "squad-squadra",
  "version": "0.1.0",
  "description": "AI travel agent that builds complex trip plans from real-world constraints — group dynamics, personal tastes, logistics.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "vault": "npx tsx src/scripts/vault.ts"
  },
  "author": "Xavier Marti Bofill",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tantu-studio/squad-squadra.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "got-scraping": "^4.2.1",
    "node-html-parser": "^7.1.0",
    "undici": "^7.24.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
